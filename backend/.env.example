# ── Azure CosmosDB ────────────────────────────────────────────────────────────
COSMOS_ENDPOINT=https://YOUR_ACCOUNT.documents.azure.com:443/
COSMOS_KEY=YOUR_PRIMARY_KEY_HERE
COSMOS_DATABASE=gridstress-db

# ── API Key (shared secret between FastAPI and Next.js) ───────────────────────
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=REPLACE_WITH_YOUR_GENERATED_KEY
